# Application
APP_ENV=local
APP_NAME=IlliniGuide Serve
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=5173

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=illiniguideserve
POSTGRES_USER=illiniguideserve
POSTGRES_PASSWORD=illiniguideserve
DATABASE_URL=postgresql+psycopg://illiniguideserve:illiniguideserve@localhost:5432/illiniguideserve

# LLM serving
# Valid values (see PROJECT_SOP.md §13.1): mock, vllm_remote, external_debug
LLM_BACKEND=mock

# vllm_remote backend: point at your self-hosted vLLM OpenAI-compatible server
# (e.g. http://ilab-h100:8000). VLLM_API_KEY is optional for local vLLM.
VLLM_BASE_URL=
VLLM_API_KEY=
MODEL_NAME=

# external_debug backend: development-only fallback to a public OpenAI-compatible
# provider. Never claim self-hosted serving when this is the active backend.
# If unset, external_debug falls back to VLLM_BASE_URL / VLLM_API_KEY.
EXTERNAL_LLM_BASE_URL=
EXTERNAL_LLM_API_KEY=

# Embeddings
EMBEDDING_MODEL_NAME=

# Observability
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
